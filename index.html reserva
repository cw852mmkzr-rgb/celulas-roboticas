function handleMetasInput(key,robo,campo,valor){
  const c = celulas[key];
  const chave = getMetasChave(key);
  if(!c.metas_dias) c.metas_dias={};
  if(!c.metas_dias[chave]) c.metas_dias[chave]={};
  if(!c.metas_dias[chave][robo]) c.metas_dias[chave][robo]={};
  const rd = c.metas_dias[chave][robo];
  const pontos = parseInt(rd.pontos)||0;
  const numVal = parseInt(valor)||0;
  let valorFinal = valor;

  // Só divide se não tiver # (ajuste técnico)
  if(pontos>1 && numVal>0 && !String(valor).includes('#')){
    const dividido = Math.round(numVal/pontos);
    if(dividido>=1 && dividido<=999 && dividido!==numVal){
      valorFinal = String(dividido);
      const inp = document.getElementById(`inp-${robo}-${campo}`);
      if(inp) inp.value = valorFinal;
    }
  }

  // aplica cor correta sem rerenderizar
  const meta = parseInt(rd.meta)||0;
  const {num, tipo} = parseCelVal(valorFinal);
  const inp = document.getElementById(`inp-${robo}-${campo}`);
  if(inp){
    inp.className = 'hora-inp';
    const horaOrigem = [...HORAS_DIA,...HORAS_NOITE].find(h=>campoH(h)===campo)||'';
    const isCafe = HORAS_CAFE.includes(horaOrigem);
    if(isCafe) inp.classList.add('cafe');
    else if(tipo==='ajuste') inp.classList.add('cell-adj');
    else if(num>0){
      if(meta>0&&num>=meta) inp.classList.add('cell-ok');
      else if(meta>0&&num<meta) inp.classList.add('cell-fail');
      else inp.classList.add('cell-ok');
    }
  }
  updateMetasCell(key,robo,campo,valorFinal);
}

