function calcProducaoPorPeca(){
  const metasKey=Object.keys(celulas).find(k=>getCellTipo(k)==='metas');
  if(!metasKey||!celulas[metasKey].metas_dias)return{};
  const resultado={};
  Object.entries(celulas[metasKey].metas_dias).forEach(([chave,diaData])=>{
    ROBOS.forEach(robo=>{
      const rd=(diaData[robo])||{};
      const cod=(rd.cod||'').trim();
      if(!cod||cod==='—'||cod==='')return;
      const totalRobo=[...HORAS_DIA,...HORAS_NOITE].reduce((s,h)=>s+(parseCelVal((rd[campoH(h)])||'').num),0);
      if(totalRobo<=0)return;
      if(!resultado[cod])resultado[cod]={total:0,dias:{},robos:{}};
      if(!resultado[cod].dias[chave])resultado[cod].dias[chave]=0;
      resultado[cod].dias[chave]+=totalRobo;
      resultado[cod].total+=totalRobo;
      if(!resultado[cod].robos[robo])resultado[cod].robos[robo]={total:0,dias:{}};
      resultado[cod].robos[robo].total+=totalRobo;
      if(!resultado[cod].robos[robo].dias[chave])resultado[cod].robos[robo].dias[chave]=0;
      resultado[cod].robos[robo].dias[chave]+=totalRobo;
    });
  });
  return resultado;
}

