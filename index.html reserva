function updateMaquinaStatus(id, status){
  if(!mapaDados.maquinas[id]) return;
  mapaDados.maquinas[id].status = status;
  saveMapaDados();
  renderMapaProducao();
  abrirPainelMaquina(id);
  showToast("Status atualizado ✓");
}

function updateMaquinaCampo(id, campo, valor){
  if(!mapaDados.maquinas[id]) return;
  mapaDados.maquinas[id][campo] = valor;
  saveMapaDados();
  showToast("Salvo ✓");
}
