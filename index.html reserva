let _manuRoboAtual = null;
let _manuIdxAtual = null;

function editarManu(key,robo,idx){
  const m = celulas[key].manutencoes[robo][idx];
  _manuRoboAtual = robo;
  _manuIdxAtual = idx;
  document.getElementById("editManuDescricao").value = m.descricao||'';
  document.getElementById("editManuResponsavel").value = m.responsavel||'';
  document.getElementById("editManuData").value = m.data||'';
  document.getElementById("modalEditManu").style.display = 'flex';
}

function salvarEdicaoManu(){
  const desc = document.getElementById("editManuDescricao").value.trim();
  if(!desc){ showToast("Descrição obrigatória!", true); return; }
  const resp = document.getElementById("editManuResponsavel").value.trim();
  const data = document.getElementById("editManuData").value.trim();
  celulas[selected].manutencoes[_manuRoboAtual][_manuIdxAtual].descricao = desc;
  celulas[selected].manutencoes[_manuRoboAtual][_manuIdxAtual].responsavel = resp;
  celulas[selected].manutencoes[_manuRoboAtual][_manuIdxAtual].data = data;
  saveToAPI(celulas);
  document.getElementById("modalEditManu").style.display = 'none';
  renderManutencao();
  showToast("Manutenção atualizada ✓");
}

function toggleManuRobo(robo){
  const el = document.getElementById(`manu-list-${robo}`);
  if(!el) return;
  const open = el.style.display !== 'none' && el.style.display !== '';
  el.style.display = open ? 'none' : 'flex';
}

function abrirModalManu(robo){
  _manuRoboAtual = robo;
  document.getElementById("manuRoboLabel").textContent = robo;
  document.getElementById("manu_descricao").value = '';
  document.getElementById("manu_responsavel").value = '';
  document.getElementById("modalManu").style.display = 'flex';
}

function fecharModalManu(){
  document.getElementById("modalManu").style.display = 'none';
}

function salvarManu(){
  const desc = document.getElementById("manu_descricao").value.trim();
  if(!desc){ showToast("Informe a descrição!", true); return; }
  const resp = document.getElementById("manu_responsavel").value.trim();
  const now = new Date().toLocaleString("pt-BR",{day:"2-digit",month:"2-digit",year:"numeric",hour:"2-digit",minute:"2-digit"});
  if(!celulas[selected].manutencoes) celulas[selected].manutencoes = {};
  if(!celulas[selected].manutencoes[_manuRoboAtual]) celulas[selected].manutencoes[_manuRoboAtual] = [];
  celulas[selected].manutencoes[_manuRoboAtual].push({descricao:desc, responsavel:resp, data:now, concluido:false});
  saveToAPI(celulas);
  fecharModalManu();
  renderManutencao();
  showToast("Manutenção adicionada ✓");
}

function concluirManu(key,robo,idx){
  const realizador = prompt("Quem realizou a manutenção?","");
  if(realizador === null) return; // cancelou
  const now = new Date().toLocaleString("pt-BR",{day:"2-digit",month:"2-digit",year:"numeric",hour:"2-digit",minute:"2-digit"});
  celulas[key].manutencoes[robo][idx].concluido = true;
  celulas[key].manutencoes[robo][idx].data_conclusao = now;
  celulas[key].manutencoes[robo][idx].realizado_por = realizador.trim()||'—';
  saveToAPI(celulas);
  renderManutencao();
  showToast("Manutenção concluída ✓");
}

function excluirManu(key,robo,idx){
  if(!confirm("Excluir esta manutenção?")) return;
  celulas[key].manutencoes[robo].splice(idx,1);
  saveToAPI(celulas);
  renderManutencao();
  showToast("Excluído ✓");
}

