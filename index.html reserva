function openXlsxModal(){xlsxPendingData=null;document.getElementById("xlsxPreview").style.display="none";document.getElementById("btnConfirmXlsx").style.display="none";document.getElementById("xlsxFileInput").value="";document.getElementById("xlsxModalEl").classList.add("open");}
function closeXlsxModal(){document.getElementById("xlsxModalEl").classList.remove("open");xlsxPendingData=null;}
function handleXlsxFile(file){
  if(!file)return;const reader=new FileReader();
  reader.onload=function(e){
    try{
      const data=new Uint8Array(e.target.result);const wb=XLSX.read(data,{type:"array"});
      const ws=wb.Sheets[wb.SheetNames[0]];const rows=XLSX.utils.sheet_to_json(ws,{header:1,defval:""});
      const dataRows=rows.slice(1).filter(r=>r[0]!==""&&r[0]!==undefined);
      if(dataRows.length===0){showToast("Planilha vazia!",true);return;}
      xlsxPendingData=[];let previewHTML="";let found=0,notFound=0;
      dataRows.forEach(row=>{
        let rawKey=String(row[0]).trim().replace(/\D/g,"");const key=rawKey.padStart(2,"0");
        const ciclos=parseInt(row[1])||0;const meta=parseInt(row[2])||0;const exists=!!celulas[key];
        if(exists)found++;else notFound++;xlsxPendingData.push({key,ciclos,meta,exists});
        previewHTML+=`<div class="xlsx-row"><span class="xlsx-cell-num">C${key}</span><span class="xlsx-val">Ciclos: <b>${ciclos}</b></span><span class="xlsx-val">Meta: <b>${meta}</b></span><span class="${exists?'xlsx-found':'xlsx-notfound'}">${exists?'✓ encontrada':'✗ não existe'}</span></div>`;
      });
      document.getElementById("xlsxPreviewList").innerHTML=previewHTML;
      document.getElementById("xlsxSummary").innerHTML=`<span style="color:#00e87a">${found} célula(s) serão atualizadas</span>`+(notFound>0?` · <span style="color:#ff4d4d">${notFound} não encontrada(s)</span>`:"");
      document.getElementById("xlsxPreview").style.display="block";
      document.getElementById("btnConfirmXlsx").style.display=found>0?"inline-block":"none";
    }catch(err){showToast("Erro ao ler o arquivo!",true);}
  };reader.readAsArrayBuffer(file);
}
function confirmXlsxImport(){
  if(!xlsxPendingData)return;let updated=0;
  xlsxPendingData.forEach(({key,ciclos,meta,exists})=>{if(exists){celulas[key].ciclos_hoje=ciclos;if(meta>0)celulas[key].meta_dia=meta;updated++;}});
  saveToAPI(celulas);closeXlsxModal();renderSidebar();renderDetail();showToast(`${updated} célula(s) atualizada(s) ✓`);
}

