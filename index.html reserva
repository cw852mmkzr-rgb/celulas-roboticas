function handleImgUpload(file){
  if(!file||!selected)return;
  const canvas = document.createElement('canvas');
  const ctx = canvas.getContext('2d');
  const img = new Image();
  const url = URL.createObjectURL(file);
  img.onload = async function(){
    const maxSize = 800;
    let w = img.width, h = img.height;
    if(w>maxSize||h>maxSize){
      if(w>h){ h=Math.round(h*maxSize/w); w=maxSize; }
      else { w=Math.round(w*maxSize/h); h=maxSize; }
    }
    canvas.width=w; canvas.height=h;
    ctx.drawImage(img,0,0,w,h);
    const compressed = canvas.toDataURL('image/jpeg', 0.85);
    URL.revokeObjectURL(url);

    try{
      const r = await fetch(SUPABASE_URL+"/rest/v1/dados?id=eq.main&select=imagens",{headers:HEADERS_SB});
      const d = await r.json();
      const imgsAtuais = (d&&d[0]&&d[0].imagens) ? d[0].imagens : {};
      // Nunca mexe no _gabaritagem
      const gab = imgsAtuais._gabaritagem;
      imgsAtuais[selected] = compressed;
      if(gab !== undefined) imgsAtuais._gabaritagem = gab;
      await fetch(SUPABASE_URL+"/rest/v1/dados?id=eq.main",{method:"PATCH",headers:HEADERS_SB,body:JSON.stringify({imagens:imgsAtuais})});
      celulas[selected].img_peca = compressed;
      renderDetail();
      showToast("Imagem salva ✓");
    }catch(e){
      celulas[selected].img_peca = compressed;
      saveToAPI(celulas);
      renderDetail();
      showToast("Imagem salva ✓");
    }
  };
  img.src = url;
}
