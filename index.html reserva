async function backupGabaritagem(){
  try{
    const r = await fetch(SUPABASE_URL+"/rest/v1/dados?id=eq.main&select=imagens",{headers:HEADERS_SB});
    const d = await r.json();
    const gab = (d&&d[0]&&d[0].imagens&&d[0].imagens._gabaritagem) ? d[0].imagens._gabaritagem : gabDados;
    if(!gab||!Object.keys(gab).length){ showToast("Nenhum dado para exportar",true); return; }
    const now = new Date();
    const nome = `backup_gabaritagem_${String(now.getDate()).padStart(2,'0')}_${String(now.getMonth()+1).padStart(2,'0')}_${now.getFullYear()}__${String(now.getHours()).padStart(2,'0')}_${String(now.getMinutes()).padStart(2,'0')}.json`;
    const blob = new Blob([JSON.stringify(gab, null, 2)], {type:'application/json'});
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = nome;
    a.click();
    showToast("Backup baixado ✓");
  }catch(e){ showToast("Erro ao fazer backup",true); }
}

