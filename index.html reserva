<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Células Robóticas</title>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800;900&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body { background: #080b0f; color: #d8dde6; font-family: 'Courier New', monospace; min-height: 100vh; }

.topbar { background: #0f1318; border-bottom: 1px solid #1e2530; height: 52px; padding: 0 16px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 100; }
.brand { font-size: 16px; font-weight: 800; color: #fff; letter-spacing: 0.1em; }
.brand span { color: #00e87a; }
.badge { font-size: 10px; padding: 4px 12px; border-radius: 99px; letter-spacing: 0.1em; text-transform: uppercase; }
.badge-admin { background: #00e87a20; border: 1px solid #00e87a40; color: #00e87a; }
.badge-viewer { background: #3d9eff20; border: 1px solid #3d9eff40; color: #3d9eff; }
.badge-metas { background: #a78bfa20; border: 1px solid #a78bfa40; color: #a78bfa; }

.layout { display: flex; height: calc(100vh - 52px); }
.sidebar { width: 200px; background: #0f1318; border-right: 1px solid #1e2530; overflow-y: auto; flex-shrink: 0; transition: transform 0.25s; }
.sidebar-hdr { padding: 10px 14px; font-size: 10px; color: #4a5568; text-transform: uppercase; letter-spacing: 0.15em; border-bottom: 1px solid #1e2530; display: flex; justify-content: space-between; align-items: center; }
.cell-item { padding: 11px 14px; border-bottom: 1px solid #1e2530; cursor: pointer; display: flex; align-items: center; gap: 8px; border-left: 3px solid transparent; transition: all 0.15s; }
.cell-item:hover { background: #ffffff06; }
.cell-item.active { background: #00e87a08; border-left-color: #00e87a; }
.cell-num { font-size: 18px; font-weight: 800; color: #fff; min-width: 26px; }
.cell-info { flex: 1; min-width: 0; }
.cell-name { font-size: 11px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; font-family: 'Montserrat', sans-serif; font-weight: 600; }
.cell-peca { font-size: 10px; color: #4a5568; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-top: 2px; }
.dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
.dot-green  { background: #00e87a; box-shadow: 0 0 5px #00e87a; }
.dot-amber  { background: #ffb300; box-shadow: 0 0 5px #ffb300; }
.dot-blue   { background: #3d9eff; box-shadow: 0 0 5px #3d9eff; }
.dot-red    { background: #ff4d4d; box-shadow: 0 0 5px #ff4d4d; }
.dot-purple { background: #a78bfa; box-shadow: 0 0 5px #a78bfa; }
.dot-orange { background: #ff6a00; box-shadow: 0 0 5px #ff6a00; }
.dot-gray  { background: #4a5568; }

.btn-menu { display: none; background: none; border: none; color: #d8dde6; font-size: 22px; cursor: pointer; padding: 4px 8px; line-height: 1; }
.sidebar-overlay { display: none; position: fixed; inset: 0; background: #000000aa; z-index: 149; }
.sidebar-overlay.open { display: block; }

.main { flex: 1; overflow-y: auto; padding: 20px; }

.section { background: #0f1318; border: 1px solid #1e2530; border-radius: 10px; padding: 16px 18px; margin-bottom: 14px; }
.sec-title { font-size: 10px; color: #4a5568; text-transform: uppercase; letter-spacing: 0.15em; margin-bottom: 12px; padding-bottom: 8px; border-bottom: 1px solid #1e2530; display: flex; justify-content: space-between; align-items: center; }
.grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.grid3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; }
.grid4 { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 12px; }
.field { display: flex; flex-direction: column; gap: 4px; }
.field label { font-size: 13px; color: #4a5568; text-transform: uppercase; letter-spacing: 0.1em; }
.field input, .field select { background: transparent; border: 1px solid transparent; border-radius: 6px; padding: 8px 10px; font-family: 'Courier New', monospace; font-size: 20px; color: #d8dde6; width: 100%; transition: all 0.15s; }
.field input:focus, .field select:focus { outline: none; border-color: #00e87a; background: #00e87a08; color: #fff; }
.field input[readonly] { cursor: default; color: #d8dde6; }
.field input.green { color: #00e87a; font-weight: 700; }
.field select { background: #0f1318; cursor: pointer; }

.alert-item { display: flex; align-items: center; gap: 8px; background: #ffb30010; border: 1px solid #ffb30025; border-radius: 6px; padding: 7px 10px; margin-bottom: 7px; }
.alert-item input { flex: 1; background: transparent; border: none; font-family: 'Courier New', monospace; font-size: 20px; color: #ffd166; outline: none; }
.alert-item input[readonly] { color: #b8960a; cursor: default; }
.btn-x { background: none; border: none; color: #4a5568; cursor: pointer; font-size: 13px; padding: 2px 6px; }
.btn-x:hover { color: #ff4d4d; }

.btn { font-family: 'Courier New', monospace; font-size: 11px; letter-spacing: 0.08em; padding: 6px 14px; border-radius: 6px; border: none; cursor: pointer; text-transform: uppercase; transition: all 0.15s; }
.btn:hover { filter: brightness(1.2); }
.btn-green { background: #00e87a; color: #000; font-weight: 800; }
.btn-gray { background: #1e2530; color: #d8dde6; border: 1px solid #2e3b4e; }
.btn-red { background: transparent; color: #ff4d4d; border: 1px solid #ff4d4d30; }
.btn-blue { background: #3d9eff20; color: #3d9eff; border: 1px solid #3d9eff40; }

.detail-hdr { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 18px; flex-wrap: wrap; gap: 10px; }
.detail-title { font-size: 24px; font-weight: 800; color: #fff; letter-spacing: 0.04em; }
.detail-sub { font-size: 11px; color: #4a5568; margin-top: 4px; }
.status-badge { display: flex; align-items: center; gap: 7px; padding: 7px 12px; border-radius: 8px; }

.img-upload-box { display: flex; flex-direction: column; align-items: center; justify-content: center; overflow: hidden; position: relative; background: #080b0f; width: 100%; height: 100%; }
.img-upload-box img { width: 100%; height: 100%; object-fit: contain; display: block; }
.img-upload-box .img-placeholder { font-size: 10px; color: #2a3040; text-align: center; padding: 8px; line-height: 1.6; }
.img-upload-box .img-overlay { position: absolute; inset: 0; background: #000000cc; display: flex; flex-direction: column; align-items: center; justify-content: center; opacity: 0; transition: opacity 0.2s; gap: 4px; }
.img-upload-box:hover .img-overlay { opacity: 1; }
.img-overlay span { font-size: 10px; color: #fff; letter-spacing: 0.06em; }

.lightbox { position: fixed; inset: 0; background: #000000ee; display: flex; align-items: center; justify-content: center; z-index: 999; opacity: 0; pointer-events: none; transition: opacity 0.2s; cursor: zoom-out; }
.lightbox.open { opacity: 1; pointer-events: all; }
.lightbox img { max-width: 92vw; max-height: 92vh; object-fit: contain; border-radius: 8px; box-shadow: 0 0 60px #00000080; transform: scale(0.95); transition: transform 0.2s; }
.lightbox.open img { transform: scale(1); }
.lightbox-close { position: absolute; top: 18px; right: 22px; font-size: 28px; color: #fff; cursor: pointer; background: none; border: none; opacity: 0.7; }

.login-wrap { min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 20px; }
.login-box { background: #0f1318; border: 1px solid #1e2530; border-radius: 16px; padding: 36px 30px; width: 100%; max-width: 360px; text-align: center; }
.login-icon { font-size: 38px; margin-bottom: 8px; }
.login-title { font-size: 22px; font-weight: 800; color: #fff; letter-spacing: 0.08em; margin-bottom: 4px; font-family: 'Montserrat', sans-serif; }
.login-sub { font-size: 10px; color: #4a5568; letter-spacing: 0.15em; margin-bottom: 28px; }
.login-input { width: 100%; background: #080b0f; border: 1px solid #1e2530; border-radius: 8px; padding: 11px 14px; font-family: 'Courier New', monospace; font-size: 14px; color: #d8dde6; text-align: center; letter-spacing: 0.15em; margin-bottom: 10px; outline: none; transition: all 0.2s; }
.login-input:focus { border-color: #00e87a; color: #fff; }
.login-input.err { border-color: #ff4d4d60; color: #ff8888; }
.login-err { color: #ff6b6b; font-size: 12px; margin-bottom: 8px; }
.login-btn-main { width: 100%; background: #00e87a; color: #000; border: none; border-radius: 8px; padding: 12px; font-family: 'Courier New', monospace; font-size: 12px; font-weight: 800; letter-spacing: 0.1em; cursor: pointer; margin-bottom: 8px; text-transform: uppercase; }
.login-btn-sec { width: 100%; background: transparent; color: #4a5568; border: 1px solid #1e2530; border-radius: 8px; padding: 10px; font-family: 'Courier New', monospace; font-size: 11px; cursor: pointer; letter-spacing: 0.06em; }
.login-hint { margin-top: 20px; font-size: 10px; color: #2a3040; }

.overlay { position: fixed; inset: 0; background: #000000bb; display: flex; align-items: center; justify-content: center; z-index: 200; opacity: 0; pointer-events: none; transition: opacity 0.2s; }
.overlay.open { opacity: 1; pointer-events: all; }
.modal { background: #0f1318; border: 1px solid #1e2530; border-radius: 12px; padding: 26px; width: 360px; max-width: 95vw; }
.modal-title { font-size: 18px; font-weight: 800; color: #fff; margin-bottom: 18px; letter-spacing: 0.06em; }
.modal-field { margin-bottom: 12px; }
.modal-field label { display: block; font-size: 10px; color: #4a5568; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 4px; }
.modal-input { width: 100%; background: #080b0f; border: 1px solid #1e2530; border-radius: 6px; padding: 8px 10px; font-family: 'Courier New', monospace; font-size: 13px; color: #d8dde6; outline: none; }
.modal-input:focus { border-color: #00e87a; color: #fff; }
.modal-actions { display: flex; gap: 8px; justify-content: flex-end; margin-top: 18px; }

.xlsx-preview { background: #080b0f; border: 1px solid #1e2530; border-radius: 8px; padding: 12px; margin-top: 12px; max-height: 220px; overflow-y: auto; font-size: 11px; }
.xlsx-row { display: flex; gap: 10px; padding: 5px 0; border-bottom: 1px solid #1e2530; align-items: center; }
.xlsx-row:last-child { border-bottom: none; }
.xlsx-cell-num { color: #00e87a; font-weight: 800; min-width: 30px; }
.xlsx-val { color: #d8dde6; }
.xlsx-found { color: #00e87a; font-size: 10px; }
.xlsx-notfound { color: #ff4d4d; font-size: 10px; }

.toast { position: fixed; bottom: 20px; right: 20px; padding: 10px 18px; border-radius: 8px; font-size: 12px; font-weight: 700; letter-spacing: 0.06em; z-index: 9999; opacity: 0; transform: translateY(8px); transition: all 0.25s; pointer-events: none; }
.toast.show { opacity: 1; transform: translateY(0); }
.toast.ok { background: #00e87a; color: #000; }
.toast.error { background: #ff4d4d; color: #fff; }
@keyframes pisca { 0%,100%{opacity:1} 50%{opacity:0.3} }
@keyframes spin { to { transform: rotate(360deg); } }

/* ── DASHBOARD TV ── */
#dashboardScreen { display:none; position:fixed; inset:0; background:#04070d; z-index:100; flex-direction:column; overflow:hidden; }
.dash-header { display:flex; justify-content:space-between; align-items:center; padding:10px 16px; border-bottom:2px solid #1e2530; background:#080b0f; flex-shrink:0; flex-wrap:wrap; gap:8px; }
.dash-title { font-size:22px; font-weight:900; color:#fff; letter-spacing:0.1em; font-family:'Montserrat',sans-serif; }
.dash-clock { font-size:clamp(24px,6vw,52px); font-weight:900; color:#00e87a; letter-spacing:0.1em; font-variant-numeric:tabular-nums; }
.dash-date { font-size:14px; color:#4a5568; text-align:right; margin-top:2px; }
.dash-footer { flex-shrink:0; background:#080b0f; border-top:2px solid #1e2530; padding:10px 20px; }
.dash-footer-title { font-size:11px; color:#4a5568; text-transform:uppercase; letter-spacing:0.15em; margin-bottom:8px; }
.dash-horas { display:flex; gap:8px; overflow-x:auto; padding-bottom:4px; }
.dash-hora-card { flex-shrink:0; background:#0a0d12; border:1px solid #1e2530; border-radius:10px; padding:8px 14px; text-align:center; min-width:80px; }
.dash-hora-label { font-size:16px; color:#4a5568; margin-bottom:4px; font-weight:700; }
.dash-hora-val { font-size:32px; font-weight:900; color:#d8dde6; }
.dash-hora-card.meta-ok .dash-hora-val { color:#00e87a; }
.dash-hora-card.meta-fail .dash-hora-val { color:#ff4d4d; }
.dash-hora-card.cafe { background:#ffb30008; border-color:#ffb30030; }
.dash-hora-card.cafe .dash-hora-label { color:#8a6200; }
.dash-exit { background:none; border:1px solid #1e2530; color:#4a5568; border-radius:6px; padding:6px 14px; font-size:13px; cursor:pointer; font-family:'Courier New',monospace; }
.dash-exit:hover { color:#ff4d4d; border-color:#ff4d4d40; }
.dash-robo-wrap { height:100%; display:flex; align-items:center; justify-content:center; gap:32px; padding:16px; position:relative; overflow:hidden; flex-wrap:wrap; }
.dash-robo-svg { flex-shrink:0; }
.dash-robo-svg svg { width:clamp(80px,14vw,180px); height:auto; }
.dash-info { display:flex; flex-direction:column; align-items:center; gap:12px; flex:1; min-width:240px; max-width:700px; }
.dash-rn { font-size:clamp(13px,2vw,20px); color:#4a5568; letter-spacing:0.2em; text-transform:uppercase; }
.dash-nome { font-size:clamp(22px,4vw,44px); font-weight:900; color:#fff; margin:2px 0; text-align:center; font-family:'Montserrat',sans-serif; }
.dash-cod { font-size:clamp(14px,2.2vw,22px); color:#ffb300; font-weight:700; }
.dash-box { background:#080b0f; border:3px solid #1e2530; border-radius:24px; padding:clamp(16px,3vw,36px) clamp(20px,5vw,80px); text-align:center; width:100%; box-sizing:border-box; }
.dash-prod-h { font-size:clamp(12px,1.8vw,18px); color:#4a5568; letter-spacing:0.2em; text-transform:uppercase; margin-bottom:6px; }
.dash-prod-n { font-size:clamp(80px,18vw,200px); font-weight:900; line-height:0.9; font-variant-numeric:tabular-nums; }
.dash-meta-txt { font-size:clamp(14px,2.2vw,22px); color:#4a5568; margin-top:8px; }
.dash-badge { font-size:clamp(16px,2.8vw,32px); font-weight:900; letter-spacing:0.1em; padding:clamp(8px,1.5vw,16px) clamp(20px,3vw,48px); border-radius:99px; text-align:center; }
.dash-faltou { font-size:clamp(13px,2vw,20px); color:#4a5568; text-align:center; }
.dash-dots { display:flex; gap:5px; flex-wrap:wrap; justify-content:center; }
@media(max-width:600px){ .dash-robo-wrap{ flex-direction:column; gap:8px; padding:8px; } .dash-robo-svg svg{ width:clamp(60px,20vw,100px); } }

/* Animação robô */
@keyframes armUp   { 0%,100%{transform:rotate(0deg)} 50%{transform:rotate(-30deg)} }
@keyframes armDown { 0%,100%{transform:rotate(0deg)} 50%{transform:rotate(25deg)} }
@keyframes blink   { 0%,90%,100%{opacity:1} 95%{opacity:0} }
@keyframes weld    { 0%,100%{opacity:0} 50%{opacity:1} }
@keyframes headBob { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-3px)} }

.empty { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; color: #2a3040; gap: 10px; }
.empty-icon { font-size: 40px; }

.arm-gabarito { overflow: hidden; max-height: 0; transition: max-height 0.3s ease, opacity 0.3s ease, margin-top 0.3s ease; opacity: 0; margin-top: 0; }
.arm-gabarito.open { max-height: 80px; opacity: 1; margin-top: 10px; }
.arm-highlight { outline: 2px solid #00e87a; background: #00e87a08 !important; }

.prod-day-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 8px; }
.prod-day-card { background: #080b0f; border: 1px solid #1e2530; border-radius: 10px; padding: 10px 8px; display: flex; flex-direction: column; align-items: center; gap: 6px; transition: border-color 0.15s; }
.prod-day-card:hover { border-color: #2e3b4e; }
.prod-day-card.today { border-color: #00e87a60; background: #00e87a08; }
.prod-day-num { font-size: 11px; color: #4a5568; font-weight: 700; letter-spacing: 0.1em; }
.prod-day-card.today .prod-day-num { color: #00e87a; }
.prod-day-input { background: transparent; border: none; outline: none; font-family: 'Courier New', monospace; font-size: 18px; font-weight: 700; color: #d8dde6; text-align: center; width: 100%; padding: 2px 0; transition: color 0.15s; }
.prod-day-input:focus { color: #00e87a; }
.prod-day-input[readonly] { cursor: default; color: #d8dde6; }
.prod-day-input.has-value { color: #00e87a; }
.prod-day-bar-wrap { width: 100%; height: 4px; background: #1e2530; border-radius: 99px; overflow: hidden; }
.prod-day-bar { height: 100%; border-radius: 99px; background: #00e87a; transition: width 0.4s; }
.prod-total-box { background: #00e87a15; border: 1px solid #00e87a30; border-radius: 10px; padding: 14px 20px; display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }

/* METAS */
.metas-table-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; touch-action: pan-x; cursor: grab; overscroll-behavior-x: contain; }
.metas-table { border-collapse: separate; border-spacing: 0; width: 100%; min-width: 700px; font-family: 'Courier New', monospace; }
.metas-table th { background: #0a0d11; color: #4a5568; font-size: 16px; text-transform: uppercase; letter-spacing: 0.08em; padding: 10px 8px; border: 1px solid #1e2530; white-space: nowrap; font-weight: 700; text-align: center; }
.metas-table th.col-robo { background: #0d1117; color: #00e87a; min-width: 65px; position:sticky; left:0; z-index:2; }
.metas-table th.col-meta { background: #0d1117; color: #3d9eff; min-width: 75px; position:sticky; left:65px; z-index:2; }
.metas-table th.col-cod  { background: #0d1117; color: #ffb300; min-width: 110px; position:sticky; left:140px; z-index:2; }
.metas-table th.col-hora { background: #0d1117; color: #d8dde6; min-width: 76px; }
.metas-table th.col-hora-noite { background: #0d1117; color: #a78bfa; min-width: 76px; }
.metas-table th.col-hora-cafe { background: #ffb30018; color: #ffb300; min-width: 76px; border-bottom: 2px solid #ffb30060; }
.metas-table th.col-sub { background: #0d1117; min-width: 80px; }
.metas-table th.col-total-geral { background: #0a0d11; color: #ffb300; min-width: 110px; border-left: 2px solid #ffb30040; }
.metas-table td { border: 1px solid #1e2530; padding: 6px 6px; text-align: center; vertical-align: middle; }
.metas-table tr:hover td { background: #ffffff04; }
.metas-table td.robo-label { color: #00e87a; font-weight: 800; font-size: 13px; background: #04070d; position:sticky; left:0; z-index:1; }
.metas-table td.meta-val { color: #3d9eff; font-weight: 700; font-size: 13px; background: #04070d; position:sticky; left:65px; z-index:1; }
.metas-table td.cod-val { color: #ffb300; font-size: 12px; background: #04070d; position:sticky; left:140px; z-index:1; }
.metas-table td.sub-dia-val { font-weight: 800; font-size: 16px; background: #00e87a08; border-left: 1px solid #00e87a20; padding: 6px 8px; }
.metas-table td.sub-noite-val { font-weight: 800; font-size: 16px; background: #a78bfa08; border-left: 1px solid #a78bfa20; padding: 6px 8px; }
.metas-table td.total-geral-val { font-weight: 900; font-size: 18px; background: #ffb30012; border-left: 2px solid #ffb30040; color: #ffb300; padding: 6px 10px; }
.metas-table input.hora-inp { background: transparent; border: none; outline: none; font-family: 'Courier New', monospace; font-size: 20px; color: #d8dde6; text-align: center; width: 100%; padding: 4px 0; font-weight: 700; }
.metas-table input.hora-inp:focus { color: #fff; }
.metas-table input.hora-inp[readonly] { cursor: default; color: #d8dde6; }
.metas-table input.hora-inp.cafe { color: #ffb300; }
.metas-table input.hora-inp.cafe[readonly] { color: #8a6200; }
.metas-table input.hora-inp.cafe:focus { color: #ffe066; }
.metas-table input.meta-inp, .metas-table input.cod-inp { background: transparent; border: none; outline: none; font-family: 'Courier New', monospace; font-size: 14px; width: 100%; padding: 4px 0; text-align: center; }
.metas-table input.meta-inp { color: #3d9eff; font-weight: 700; }
.metas-table input.meta-inp[readonly] { color: #00e87a; cursor: default; }
.metas-table input.cod-inp { color: #d8dde6; }
.metas-table input.cod-inp[readonly] { color: #ffb300; cursor: default; }
.cell-ok   { background: #00e87a20 !important; color: #00e87a !important; }
.cell-fail { background: #ff4d4d20 !important; color: #ff4d4d !important; }
.cell-adj  { background: #3d9eff20 !important; color: #3d9eff !important; }

/* seletor de data */
.date-sel { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
.date-sel select { background: #0f1318; border: 1px solid #1e2530; border-radius: 6px; padding: 5px 10px; font-family: 'Courier New', monospace; font-size: 12px; color: #d8dde6; cursor: pointer; outline: none; }
.date-sel label { font-size: 10px; color: #4a5568; text-transform: uppercase; letter-spacing: 0.1em; }

/* histórico eletrodo */
.hist-item { display: flex; align-items: center; gap: 8px; background: #080b0f; border: 1px solid #1e2530; border-radius: 6px; padding: 6px 10px; margin-bottom: 6px; }
.hist-item-data { font-size: 11px; color: #4a5568; min-width: 140px; white-space: nowrap; }
.hist-item-val { flex: 1; font-size: 13px; color: #d8dde6; font-weight: 600; }
.hist-empty { font-size: 12px; color: #2a3040; }

/* sidebar grupos */
.sidebar-group-label { padding: 6px 14px 4px; font-size: 9px; color: #2a3040; text-transform: uppercase; letter-spacing: 0.15em; font-weight: 700; }
.sidebar-ver-mais { padding: 9px 14px; cursor: pointer; text-align: center; color: #00e87a; font-size: 11px; font-weight: 700; letter-spacing: 0.08em; background: #00e87a08; border-top: 1px solid #1e2530; }
.sidebar-ver-mais:hover { background: #00e87a15; }
.sidebar-recolher { padding: 9px 14px; cursor: pointer; text-align: center; color: #4a5568; font-size: 11px; font-weight: 700; letter-spacing: 0.08em; border-top: 1px solid #1e2530; }
.sidebar-recolher:hover { background: #ffffff06; }

::-webkit-scrollbar { width: 10px; height: 10px; }
::-webkit-scrollbar-track { background: #0a0d12; border-radius: 99px; }
::-webkit-scrollbar-thumb { background: #2a3040; border-radius: 99px; border: 2px solid #0a0d12; }
::-webkit-scrollbar-thumb:hover { background: #3d4a60; }
::-webkit-scrollbar-corner { background: #0a0d12; }

.metas-carousel { display:none; }
@media (max-width: 700px) {
  .metas-table-wrap { display:none; }
  .metas-carousel { display:block; }
  .metas-car-nav { display:flex; align-items:center; justify-content:space-between; padding:6px 0; margin-bottom:6px; }
  .metas-car-nav button { background:#1e2530; border:1px solid #2a3040; color:#d8dde6; border-radius:8px; padding:8px 18px; font-size:20px; cursor:pointer; }
  .metas-car-nav span { font-size:13px; color:#4a5568; font-family:'Courier New',monospace; font-weight:700; }
  .metas-car-table { width:100%; border-collapse:collapse; font-family:'Courier New',monospace; }
  .metas-car-table th { background:#080b0f; color:#4a5568; font-size:13px; padding:8px 6px; border:1px solid #1e2530; text-align:center; }
  .metas-car-table td { border:1px solid #1e2530; padding:8px 4px; text-align:center; font-size:15px; }
  .btn-menu { display: block; }
  .sidebar { position: fixed; top: 52px; left: 0; bottom: 0; width: 260px; z-index: 150; transform: translateX(-100%); }
  .sidebar.open { transform: translateX(0); }
  .main { padding: 8px; width: 100%; box-sizing: border-box; }
  .grid2 { grid-template-columns: 1fr; }
  .grid3 { grid-template-columns: 1fr; }
  .grid4 { grid-template-columns: 1fr 1fr; }
  .peca-grid { grid-template-columns: 1fr !important; }
  .detail-title { font-size: 18px; }
  #savedLabel { display: none; }
  .prod-day-grid { grid-template-columns: repeat(4, 1fr); }
  /* Tabelas com scroll horizontal */
  .metas-table-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; }
  /* Header topbar compacto */
  .topbar { flex-wrap: wrap; gap: 4px; padding: 6px 10px; }
  .topbar button { font-size: 10px; padding: 4px 8px; }
  /* Células do robô em coluna */
  .detail-hdr { flex-direction: column; gap: 8px; }
  .robo-img-wrap { flex-direction: column; }
  /* Fontes menores em tabelas */
  .metas-table th { font-size: 11px !important; padding: 6px 4px !important; }
  .metas-table input.hora-inp { font-size: 14px !important; }
  /* Painel principal sem overflow */
  #mainPanel { overflow-x: hidden; }
  /* Seções em coluna única */
  .section { padding: 10px; }
  .field label { font-size: 10px; }
  .field input, .field select, .field textarea { font-size: 13px; }
}
