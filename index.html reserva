let _dashLoadTimer=null,_dashClockTimer=null,_dashSlideTimer=null;
let _dashIdx=0, _dashGeral=false, _dashRobos=[];

function _dashGetHoraCheia(){
  const h = new Date().getHours();
  const s = `${String(h).padStart(2,'0')}:00`;
  const all = [...HORAS_DIA,...HORAS_NOITE];
  if(all.includes(s)) return s;
  // Se hora atual não está no array, pega a mais próxima anterior
  for(let i = all.length-1; i >= 0; i--){
    const hNum = parseInt(all[i].split(':')[0]);
    if(hNum < h) return all[i];
  }
  return all[0];
}

function _dashTickClock(){
  const now=new Date();
  const ce=document.getElementById("dashClock");
  const he=document.getElementById("dashHoraCheia");
  const de=document.getElementById("dashDate");
  if(ce) ce.textContent=now.toLocaleTimeString("pt-BR");
  if(he) he.textContent=_dashGetHoraCheia();
  if(de) de.textContent=now.toLocaleDateString("pt-BR",{weekday:"long",day:"2-digit",month:"long",year:"numeric"});
}

async function _dashLoad(){
  try{
    const r=await fetch(SUPABASE_URL+"/rest/v1/dados?id=eq.main&select=conteudo,imagens",{headers:HEADERS_SB});
    const d=await r.json();
    if(d&&d[0]&&d[0].conteudo&&Object.keys(d[0].conteudo).length>0){
      celulas=d[0].conteudo;
      if(d[0].imagens){
        Object.entries(d[0].imagens).forEach(([k,img])=>{if(celulas[k])celulas[k].img_peca=img;});
      }
    }
  }catch(e){}
  // Atualiza lista de robôs sem resetar o índice atual
  const robosAntes = _dashRobos.length;
  _dashRobos=Object.keys(celulas).filter(k=>getCellTipo(k)==='robo').sort();
  // Só reseta índice se a lista mudou
  if(robosAntes === 0) {
    const d2=_dashGetDados(); const h2=_dashGetHoraCheia();
    _dashIdx=0;
    let t=0;
    while(t<_dashRobos.length && _dashRoboSemValor(_dashRobos[_dashIdx],d2,h2)){
      _dashIdx++; t++;
      if(_dashIdx>=_dashRobos.length){_dashIdx=0;break;}
    }
  }
  // Apenas atualiza o rodapé — não rerenderiza o slide atual
  _dashRenderFooter();
}

function _dashNextSlide(){
  if(_dashGeral){
    _dashGeral=false; _dashIdx=0;
    // Acha primeiro robô com produção
    const d=_dashGetDados(); const h=_dashGetHoraCheia();
    let t=0;
    while(t<_dashRobos.length && _dashRoboSemValor(_dashRobos[_dashIdx],d,h)){
      _dashIdx++; t++;
      if(_dashIdx>=_dashRobos.length){_dashIdx=0;break;}
    }
    clearInterval(_dashSlideTimer);
    _dashSlideTimer=setInterval(_dashNextSlide,6000);
    _dashRender(); _dashRenderFooter();
    return;
  }
  const dados=_dashGetDados();
  const hora=_dashGetHoraCheia();
  // Conta quantos robôs têm produção
  const robosComProd = _dashRobos.filter(k=>!_dashRoboSemValor(k,dados,hora));
  // Se só tem 1 ou nenhum com produção, vai direto pra tela geral
  if(robosComProd.length <= 1){
    _dashGeral=true; _dashIdx=0;
    clearInterval(_dashSlideTimer);
    _dashSlideTimer=setInterval(_dashNextSlide,40000);
    _dashRender(); _dashRenderFooter();
    return;
  }
  let tentativas=0;
  do {
    _dashIdx++;
    tentativas++;
    if(_dashIdx>=_dashRobos.length){
      _dashGeral=true; _dashIdx=0;
      clearInterval(_dashSlideTimer);
      _dashSlideTimer=setInterval(_dashNextSlide,40000);
      _dashRender(); _dashRenderFooter();
      return;
    }
  } while(tentativas < _dashRobos.length && _dashRoboSemValor(_dashRobos[_dashIdx], dados, hora));
  _dashRender(); _dashRenderFooter();
}

function _dashRoboSemValor(k, dados, hora){
  if(!k||!celulas[k]) return true;
  const rn=k.replace(/\D/g,'');
  const rd=dados[rn]||{};
  const prod=parseCelVal((rd[campoH(hora)])||'').num;
  // Pula se não tiver produção na hora atual
  return prod===0;
}

function _dashGetDados(){
  const mk=Object.keys(celulas).find(k=>getCellTipo(k)==='metas');
  if(!mk) return {};
  const mc=celulas[mk];
  if(!mc.metas_dias) return {};
  const now=new Date();
  const ano=now.getFullYear(), mes=now.getMonth(), dia=now.getDate();

  // Tenta mês 0-indexed (padrão do sistema)
  const ch1=`${ano}_${mes}_${dia}`;
  if(mc.metas_dias[ch1]) return mc.metas_dias[ch1];

  // Tenta mês 1-indexed
  const ch2=`${ano}_${mes+1}_${dia}`;
  if(mc.metas_dias[ch2]) return mc.metas_dias[ch2];

  // Sem dados para hoje — retorna vazio
  return {};
}

function _dashRender(){
  if(_dashGeral) _dashRenderGeral();
  else _dashRenderRobo(_dashRobos[_dashIdx]);
}

