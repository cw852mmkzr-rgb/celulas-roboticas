function renderRelatorio(){
  const c = celulas[selected];
  const anoAtual = new Date().getFullYear();
  const mesIdx = c.rel_mes!==undefined ? c.rel_mes : new Date().getMonth();
  const anoSel = c.rel_ano || anoAtual;

  // Localiza células auxiliares
  const metasKey = Object.keys(celulas).find(k=>getCellTipo(k)==='metas');
  const mc = metasKey ? celulas[metasKey] : null;

  // ── 1. Coleta todos os dias do mês selecionado ──
  const diasDoMes = {};  // dia -> {robos: {600: {total,meta,cod}}, totalGeral}
  if (mc && mc.metas_dias) {
    Object.entries(mc.metas_dias).forEach(([chave, diaData]) => {
      const [a,m,d] = chave.split('_');
      if (parseInt(a)!==anoSel || parseInt(m)!==mesIdx) return;
      const dia = parseInt(d);
      if (!diasDoMes[dia]) diasDoMes[dia] = {robos:{}, totalGeral:0};
      ROBOS.forEach(robo => {
        const rd = (diaData[robo])||{};
        const meta = parseInt(rd.meta)||0;
        const cod  = rd.cod||'—';
        const totalDia   = HORAS_DIA.reduce((s,h)=>s+(parseCelVal((rd[campoH(h)])||'').num),0);
        const totalNoite = HORAS_NOITE.reduce((s,h)=>s+(parseCelVal((rd[campoH(h)])||'').num),0);
        const total = totalDia+totalNoite;
        diasDoMes[dia].robos[robo] = {total, meta, cod, totalDia, totalNoite};
        diasDoMes[dia].totalGeral += total;
      });
    });
  }

  const diasComDados = Object.keys(diasDoMes).map(Number).sort((a,b)=>a-b);
  const totalMes = diasComDados.reduce((s,d)=>s+diasDoMes[d].totalGeral,0);
  const diasComProd = diasComDados.filter(d=>diasDoMes[d].totalGeral>0);
  const mediaDia = diasComProd.length>0 ? Math.round(totalMes/diasComProd.length) : 0;
  const melhorDia = diasComDados.reduce((best,d)=>diasDoMes[d].totalGeral>diasDoMes[best]?.totalGeral?d:best, diasComDados[0]);

  // ── 2. Eficiência por robô no mês ──
  const eficienciaRobo = ROBOS.map(robo => {
    let totalProd=0, diasAtivo=0, diasBateu=0, metaMedia=0, metaCount=0;
    diasComDados.forEach(d=>{
      const r = (diasDoMes[d].robos[robo])||{};
      if(r.total>0){totalProd+=r.total;diasAtivo++;}
      if(r.meta>0){metaMedia+=r.meta;metaCount++;}
      const metaEstimada = r.meta>0?r.meta*9:0;
      if(metaEstimada>0&&r.total>=metaEstimada)diasBateu++;
    });
    const mediaMetaHora = metaCount>0?Math.round(metaMedia/metaCount):0;
    // Base de 9h fixas por dia
