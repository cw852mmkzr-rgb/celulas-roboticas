function salvarEdicaoCell(keyAntigo){
  const novoNome = document.getElementById(`edit-nome-${keyAntigo}`).value.trim();
  const novoNum  = document.getElementById(`edit-num-${keyAntigo}`).value.trim().padStart(2,'0');

  if (!novoNome) { showToast("Nome não pode ser vazio", true); return; }
  if (!novoNum || isNaN(parseInt(novoNum))) { showToast("Número inválido", true); return; }

  // Atualiza o nome
  celulas[keyAntigo].nome = novoNome;

  // Se o número mudou, muda a chave
  if (novoNum !== keyAntigo) {
    if (celulas[novoNum]) { showToast("Número " + novoNum + " já existe!", true); return; }
    celulas[novoNum] = celulas[keyAntigo];
    delete celulas[keyAntigo];
    // Se era a célula selecionada, atualiza
    if (selected === keyAntigo) selected = novoNum;
  }

  saveToAPI(celulas);
  renderSidebar();
  renderDetail();
  openGerenciar(); // recarrega o modal
  showToast("Célula atualizada ✓");
}

