// ── tipo da célula detectado pelo nome ───────
function getCellTipo(k) {
  const n = (celulas[k].nome||'').toLowerCase();
  if (n.includes('armario')||n.includes('armário')||n.includes('gabarito')) return 'armario';
  if (n.includes('relat')) return 'relatorio';
  if (n.includes('produ')&&n.includes('pe')) return 'producao_peca';
  if (n.includes('produ')&&(n.includes('men')||n.includes('di'))) return 'producao_mensal';
  if (n.includes('meta')) return 'metas';
  if (n.includes('cadastro')&&n.includes('pe')) return 'cadastro_pecas';
  if (n.includes('catal')&&n.includes('pe')) return 'catalogo_pecas';
  if (n.includes('manu')) return 'manutencao';
  return 'robo';
}

function parseCelVal(raw) {
  const s = String(raw||'').trim();
  if (!s) return {num:0,tipo:'normal'};
  if (s.endsWith('#')) return {num:parseInt(s)||0, tipo:'ajuste'};
  return {num:parseInt(s)||0, tipo:'normal'};
}

function getMetasChave(key) {
  const c=celulas[key];
  const ano=c.metas_ano||new Date().getFullYear();
  const mes=c.metas_mes!==undefined?c.metas_mes:new Date().getMonth();
  const dia=c.metas_dia||new Date().getDate();
  return `${ano}_${mes}_${dia}`;
}

