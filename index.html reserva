    const meta = parseInt(rd.meta)||0;
    const cod = rd.cod||'';
    const pontosCell = isAdmin ? `<td style="color:#ff6a00;font-size:12px">${rd.pontos||'—'}</td>` : '';
    const horasCells = grupo.map(h=>{
      const isCafe = HORAS_CAFE.includes(h);
      const campo = campoH(h);
      const rawVal = (rd[campo])||'';
      const {num,isAjuste} = parseCelVal(rawVal);
      const metaH = isCafe ? Math.round(meta*0.6) : meta;
      let bg='', cor='#d8dde6';
      if(isAjuste){cor='#3d9eff';}
      else if(num>0&&meta>0){bg=num>=metaH?'#00e87a18':'#ff4d4d18';cor=num>=metaH?'#00e87a':'#ff4d4d';}
      if(isCafe&&!isAjuste){bg='#ffb30018';cor='#ffb300';}
      const isAtual = parseInt(h)===horaAtual;
      return`<td style="background:${bg};color:${cor};font-weight:700;${isAtual?'border:2px solid #ffb300;':''}">${podeEditar
        ?`<input class="hora-inp ${isCafe?'cafe':''}" type="number" min="0" value="${num>0?num:''}" placeholder="—" ${ro} onchange="updateMetasCell('${selected}',${robo},'${campo}',this.value)">`
        :`${num>0?num:'—'}`}</td>`;
    }).join('');

    const subRow = HORAS.reduce((s,h)=>s+(parseCelVal((rd[campoH(h)])||'').num),0);
    return`<tr>
      <td style="color:#00e87a;font-weight:900;font-size:15px;text-align:left;padding-left:8px;background:#04070d;position:sticky;left:0">${robo}</td>
      <td style="color:#3d9eff;font-size:13px;background:#04070d">${meta||'—'}</td>
      <td style="color:#ffb300;font-size:12px;background:#04070d">${esc(cod)||'—'}</td>
      ${horasCells}
      <td style="color:${subColor};font-weight:800;font-size:14px">${subRow>0?subRow:'—'}</td>
    </tr>`;
  }).join('');

  // Totais
  const totalRow = grupo.map(h=>{
    const s=ROBOS.reduce((acc,r)=>acc+(parseCelVal(((data[r]||{})[campoH(h)])||'').num),0);
    return`<td style="color:#d8dde6;font-weight:900;font-size:14px">${s>0?s:'—'}</td>`;
  }).join('');
  const subTotal=ROBOS.reduce((sum,r)=>sum+HORAS.reduce((s,h)=>s+(parseCelVal(((data[r]||{})[campoH(h)])||'').num),0),0);

  const de = _carIdx+1;
  const ate = Math.min(_carIdx+_carStep, total);

  return`<div class="metas-carousel-inner">
    <div class="metas-car-nav">
      <button onclick="_carPrev()" ${_carIdx===0?'disabled style="opacity:0.3"':''}>◀</button>
      <span>${grupo.map(h=>`${h}`).join(' · ')}</span>
      <button onclick="_carNext(${total})" ${_carIdx+_carStep>=total?'disabled style="opacity:0.3"':''}>▶</button>
    </div>
    <table class="metas-car-table">
      <thead><tr>
        <th style="text-align:left;padding-left:8px">Robô</th>
        <th>Meta/h</th>
        <th>Código</th>
        ${grupo.map(h=>`<th style="${HORAS_CAFE.includes(h)?'color:#ffb300':''};${parseInt(h)===horaAtual?'border:2px solid #ffb300':''}">${h}</th>`).join('')}
        <th style="color:${subColor}">${subLabel}</th>
      </tr></thead>
      <tbody>${linhas}
        <tr style="border-top:2px solid #1e2530">
          <td colspan="3" style="color:#4a5568;font-size:10px;text-align:right;padding-right:6px">TOTAL/HORA</td>
          ${totalRow}
          <td style="color:${subColor};font-weight:900;font-size:15px">${subTotal>0?subTotal:'—'}</td>
        </tr>
      </tbody>
    </table>
  </div>`;
}

function _carPrev(){
  _carIdx = Math.max(0, _carIdx - _carStep);
  renderMetasDiaria();
}
function _carNext(total){
  _carIdx = Math.min(total - _carStep, _carIdx + _carStep);
  if(_carIdx < 0) _carIdx = 0;
  renderMetasDiaria();
}

