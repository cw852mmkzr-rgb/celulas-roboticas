// ── HISTÓRICO ELETRODO ───────────────────────
function calcDesgaste(key){
  // Soma todas as peças produzidas desde a última troca de eletrodo
  const c = celulas[key];
  if(!c) return 0;
  const ultimaTroca = c.ultima_troca||'';
  if(!ultimaTroca||ultimaTroca==='—') return 0;

  // Converte data da última troca para objeto Date
  // Formato: "04/06/2026, 10:05"
  const partes = ultimaTroca.match(/(\d{2})\/(\d{2})\/(\d{4}),\s*(\d{2}):(\d{2})/);
  if(!partes) return 0;
  const dataTroca = new Date(partes[3], partes[2]-1, partes[1], partes[4], partes[5]);

  // Busca dados das metas e soma peças após a data de troca
  const metasKey = Object.keys(celulas).find(k=>getCellTipo(k)==='metas');
  if(!metasKey) return 0;
  const metas = celulas[metasKey];
  if(!metas.metas_dias) return 0;

  const roboNum = key.replace(/\D/g,'');
  let total = 0;

  Object.entries(metas.metas_dias).forEach(([chave, dia])=>{
    // chave = "2026_5_4"
    const p = chave.split('_');
    if(p.length<3) return;
    const rd = dia[roboNum]||{};
    // Verifica cada hora
    [...HORAS_DIA,...HORAS_NOITE].forEach(h=>{
      const campo = campoH(h);
      const val = parseCelVal((rd[campo])||'').num;
      if(val<=0) return;
      // Cria data da hora
      const hNum = parseInt(h.split(':')[0]);
      const dataHora = new Date(parseInt(p[0]), parseInt(p[1]), parseInt(p[2]), hNum, 0);
      if(dataHora >= dataTroca) total += val;
    });
  });

  return total;
}

function registrarTrocaEletrodo(key){
  const c=celulas[key];
  if(!c.eletrodo||c.eletrodo==='—'){showToast("Informe o eletrodo primeiro",true);return;}
