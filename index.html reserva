// Scroll horizontal nas tabelas no mobile
function fixTouchScroll(){
  document.querySelectorAll('.metas-table-wrap, .gab-table-wrap').forEach(el=>{
    let startX, startY, startScroll;
    el.addEventListener('touchstart', e=>{
      startX = e.touches[0].clientX;
      startY = e.touches[0].clientY;
      startScroll = el.scrollLeft;
    },{passive:true});
    el.addEventListener('touchmove', e=>{
      const dx = e.touches[0].clientX - startX;
      const dy = e.touches[0].clientY - startY;
      if(Math.abs(dx) > Math.abs(dy)){
        // Movimento horizontal — previne scroll da página
        e.stopPropagation();
        el.scrollLeft = startScroll - dx;
      }
    },{passive:false});
  });
}
setTimeout(fixTouchScroll, 1000);

