function updateGab(cod, dia, val){
  const chave = getGabChave();
  if(!gabDados[chave]) gabDados[chave]={codigos:[]};
  if(!gabDados[chave][cod]) gabDados[chave][cod]={};
  const n = parseInt(val)||0;
  if(n>0) gabDados[chave][cod][dia]=n;
  else delete gabDados[chave][cod][dia];

  const mes = parseInt(document.getElementById("gabMes")?.value||0);
  const ano = parseInt(document.getElementById("gabAno")?.value||2026);
  const dias = getDiasUteis(ano, mes);
  const codigos = gabDados[chave].codigos||[];

  // Atualiza total da linha
  const totalLinha = dias.reduce((s,d)=>s+(parseInt((gabDados[chave][cod]||{})[d])||0),0);
  const prog = parseInt(gabDados[chave][cod]?._prog||0);
  const falta = prog>0?prog-totalLinha:null;
  const pct = prog>0?Math.round(totalLinha/prog*100):null;
  const corPct = pct>=100?'#00e87a':pct>=70?'#ffb300':'#ff4d4d';

  const elTotal = document.getElementById(`gabtotal-${cod}`);
  if(elTotal) elTotal.textContent = totalLinha>0?totalLinha.toLocaleString('pt-BR'):'—';

  const elFalta = document.getElementById(`gabfalta-${cod}`);
  if(elFalta){
    elFalta.style.color = falta===null?'#2a3040':falta<=0?'#00e87a':'#ff6a00';
    elFalta.textContent = falta===null?'—':falta<=0?'✓':falta.toLocaleString('pt-BR');
  }
  const elPct = document.getElementById(`gabpct-${cod}`);
  if(elPct){
    elPct.style.color = pct===null?'#2a3040':corPct;
    elPct.textContent = pct===null?'—':pct+'%';
  }

  // Atualiza total da coluna do dia
  const totalDia = codigos.reduce((s,c)=>s+(parseInt((gabDados[chave][c]||{})[dia])||0),0);
  const elDia = document.getElementById(`gabtotaldia-${dia}`);
  if(elDia){
    elDia.textContent = totalDia>0?totalDia:'—';
    elDia.style.color = totalDia>0?'#ffb300':'#2a3040';
  }

  // Atualiza total geral
  const totalGeral = codigos.reduce((s,c)=>s+dias.reduce((ss,d)=>ss+(parseInt((gabDados[chave][c]||{})[d])||0),0),0);
  const elGeral = document.getElementById("gabtotalgeral");
  if(elGeral) elGeral.textContent = totalGeral>0?totalGeral.toLocaleString('pt-BR'):'—';

  saveGabDados();
}

function updateGabProg(cod, val){
  const chave = getGabChave();
  if(!gabDados[chave]) gabDados[chave]={codigos:[]};
  if(!gabDados[chave][cod]) gabDados[chave][cod]={};
  const n = parseInt(val)||0;
  if(n>0) gabDados[chave][cod]._prog=n;
  else delete gabDados[chave][cod]._prog;

  // Recalcula falta e % em tempo real
  const mes = parseInt(document.getElementById("gabMes")?.value||0);
  const ano = parseInt(document.getElementById("gabAno")?.value||2026);
  const dias = getDiasUteis(ano, mes);
  const total = dias.reduce((s,d)=>s+(parseInt((gabDados[chave][cod]||{})[d])||0),0);
  const prog = n;
  const falta = prog>0?prog-total:null;
  const pct = prog>0?Math.round(total/prog*100):null;
  const corPct = pct>=100?'#00e87a':pct>=70?'#ffb300':'#ff4d4d';

  const elFalta = document.getElementById(`gabfalta-${cod}`);
  if(elFalta){
    elFalta.style.color = falta===null?'#2a3040':falta<=0?'#00e87a':'#ff6a00';
    elFalta.textContent = falta===null?'—':falta<=0?'✓':falta.toLocaleString('pt-BR');
  }
  const elPct = document.getElementById(`gabpct-${cod}`);
  if(elPct){
