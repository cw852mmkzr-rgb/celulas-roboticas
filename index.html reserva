  });
  const info=document.getElementById("busca-info");
  if(info){info.textContent=t?(enc>0?`${enc} encontrado(s)`:"Nenhum encontrado"):"";info.style.color=enc>0?"#00e87a":"#ff4d4d";}
}

function parseTempoPeca(str){
  if(!str||str==='—')return null; str=String(str).trim();
  const ms=str.match(/(\d+)\s*min\s*(\d*)\s*s?/i);if(ms)return parseInt(ms[1])*60+(parseInt(ms[2])||0);
  const co=str.match(/^(\d+):(\d{2})$/);if(co)return parseInt(co[1])*60+parseInt(co[2]);
  const sg=str.match(/^(\d+)\s*s$/i);if(sg)return parseInt(sg[1]);
  const nm=parseFloat(str);if(!isNaN(nm))return Math.round(nm*60);return null;
}
function calcRitmo(mh,tp){
  const mn=parseFloat(mh);const st=parseTempoPeca(tp);
  if(!mn||mn<=0||!st)return'—';
  const d=3600/mn;const ef=Math.round((st/d)*100);
  const m=Math.floor(d/60);const s=Math.round(d%60);
  return`${m>0?m+'min ':''} ${s>0?s+'s':''} / peça (${ef}% do tempo)`.trim();
}

async function loadFromAPI(){
  const active=document.activeElement;
  if(active&&(active.tagName==='INPUT'||active.tagName==='TEXTAREA'||active.tagName==='SELECT'))return;

  // Carrega cache local primeiro para resposta instantânea
  try{
    const cache = localStorage.getItem('celulas_cache');
    if(cache){
      celulas = JSON.parse(cache);
      renderSidebar();
      if(!selected){const keys=Object.keys(celulas).sort();if(keys.length){selected=keys[0];renderDetail();}}
    }
  }catch(e){}

  try{
    const controller = new AbortController();
    const timeout = setTimeout(()=>controller.abort(), 8000);
    const r=await fetch(SUPABASE_URL+"/rest/v1/dados?id=eq.main&select=conteudo,imagens",{
      headers:HEADERS_SB, signal:controller.signal
    });
    clearTimeout(timeout);
    const d=await r.json();
    if(d&&d[0]&&d[0].conteudo&&Object.keys(d[0].conteudo).length>0){
      const anterior=JSON.stringify(celulas);
      const novo=JSON.stringify(d[0].conteudo);
      if(anterior&&anterior!=='{}'&&novo!==anterior){
        const badge=document.getElementById("newDataBadge");
        if(badge) badge.style.display="inline-block";
      }
      celulas=d[0].conteudo;
      if(d[0].imagens){
        Object.entries(d[0].imagens).forEach(([k,img])=>{if(celulas[k])celulas[k].img_peca=img;});
      }
      // Salva no cache local
      try{ localStorage.setItem('celulas_cache', JSON.stringify(celulas)); }catch(e){}
    }
    else{celulas=defaultData;await saveToAPI(celulas);}
  }catch(e){
    if(!Object.keys(celulas).length) celulas=defaultData;
    if(e.name==='AbortError') showToast("Conexão lenta — usando dados locais",true);
  }

  renderSidebar();
  if(!selected){const keys=Object.keys(celulas).sort();if(keys.length){selected=keys[0];renderDetail();}}
  else{
    const tipo=getCellTipo(selected);
    // Não rerenderiza armário se tiver algum card aberto
    const temGabAberto = document.querySelector('.arm-gabarito.open');
    // Não rerenderiza catálogo se usuário scrollou para baixo
    const mainPanel = document.getElementById('mainPanel');
    const catalogoScrollado = tipo==='catalogo_pecas' && mainPanel && mainPanel.scrollTop > 50;
    if(tipo!=='robo' && !(tipo==='armario' && temGabAberto) && !catalogoScrollado) renderDetail();
    else if(catalogoScrollado) _filtrarCatalogo(); // atualiza só o tbody sem perder scroll
  }
}

async function saveToAPI(data){
  try{
    const semImg = JSON.parse(JSON.stringify(data));
    const imgs = {};
    Object.keys(semImg).forEach(k=>{ if(semImg[k]&&semImg[k].img_peca){imgs[k]=semImg[k].img_peca;semImg[k].img_peca="";} });
    // Salva dados
    await fetch(SUPABASE_URL+"/rest/v1/dados?id=eq.main",{method:"PATCH",headers:HEADERS_SB,body:JSON.stringify({conteudo:semImg,atualizado_em:new Date().toISOString()})});
    // Salva imagens preservando _gabaritagem
    if(Object.keys(imgs).length>0){
      try{
        const ri=await fetch(SUPABASE_URL+"/rest/v1/dados?id=eq.main&select=imagens",{headers:HEADERS_SB});
        const di=await ri.json();
        const imgsAtuais=(di&&di[0]&&di[0].imagens)||{};
        const gab=imgsAtuais._gabaritagem;
        Object.assign(imgsAtuais,imgs);
        if(gab!==undefined) imgsAtuais._gabaritagem=gab;
        await fetch(SUPABASE_URL+"/rest/v1/dados?id=eq.main",{method:"PATCH",headers:HEADERS_SB,body:JSON.stringify({imagens:imgsAtuais})});
      }catch(ei){}
    }
    const now=new Date().toLocaleTimeString("pt-BR",{hour:"2-digit",minute:"2-digit",second:"2-digit"});
    document.getElementById("savedLabel").textContent="salvo "+now;
    showToast("Salvo ✓");
  }catch(e){showToast("Erro ao salvar",true);}
}

function update(key,field,value){celulas[key][field]=value;saveToAPI(celulas);}
function updateAndRefreshRitmo(key,field,value){
  celulas[key][field]=value;saveToAPI(celulas);
  const el=document.getElementById("ritmoDisplay");if(el)el.value=calcRitmo(celulas[key].meta_hora,celulas[key].tempo_peca);
}

// ── SIDEBAR ──────────────────────────────────
function renderSidebar(){
  const keys=Object.keys(celulas).sort();
  document.getElementById("cellCount").textContent="Células ("+keys.length+")";

  // Separa painéis e robôs
  const paineis = keys.filter(k=>getCellTipo(k)!=='robo' && (getCellTipo(k)!=='cadastro_pecas' || isAdmin));
  const robos   = keys.filter(k=>getCellTipo(k)==='robo');
  const robosVisiveis = sidebarExpandida ? robos : robos.slice(0,1);
  const robosRestantes = robos.length-1;

  const icones = {armario:'🗄',producao_mensal:'📅',metas:'📋',producao_peca:'📦',relatorio:'📊',cadastro_pecas:'🔧',catalogo_pecas:'📋',manutencao:'🔩',robo:'⚙'};

  function itemHTML(k){
    const c=celulas[k];const s=SC[c.status]||SC["Parado"];
    const t=getCellTipo(k);const ic=icones[t]||'⚙';
    return `<div class="cell-item ${k===selected?'active':''}" onclick="selectCell('${k}')">
      <div class="cell-num" style="font-size:15px">${ic}</div>
      <div class="cell-info">
        <div class="cell-name">${c.nome}${isAdmin?` <span onclick="event.stopPropagation();renomearCelula('${k}')" style="color:#2a3040;cursor:pointer;font-size:10px" title="Renomear">✏</span>`:''}</div>
        <div class="cell-peca">${t==='robo'?(c.cliente||c.peca||'—'):''}</div>
      </div>
      <div class="dot ${s.dot}"></div>
    </div>`;
  }

  let html='';
  if(paineis.length>0){
    html+=`<div class="sidebar-group-label">Painéis</div>`;
    html+=paineis.map(itemHTML).join('');
  }
  if(robos.length>0){
    html+=`<div class="sidebar-group-label" style="border-top:1px solid #1e2530;margin-top:4px">Robôs</div>`;
    html+=robosVisiveis.map(itemHTML).join('');
    if(!sidebarExpandida&&robosRestantes>0){
      html+=`<div class="sidebar-ver-mais" onclick="toggleSidebarExpand()">▼ Ver mais ${robosRestantes} robô(s)</div>`;
    }else if(sidebarExpandida&&robos.length>1){
      html+=`<div class="sidebar-recolher" onclick="toggleSidebarExpand()">▲ Recolher</div>`;
    }
  }
  document.getElementById("sidebarList").innerHTML=html;
}

function toggleSidebarExpand(){ sidebarExpandida=!sidebarExpandida; renderSidebar(); }
function selectCell(k){ selected=k; renderSidebar(); renderDetail(); closeSidebar(); }

function renomearCelula(key){
  if(!isAdmin)return;
  const novo=prompt('Novo nome:',celulas[key].nome);
  if(novo&&novo.trim()&&novo.trim()!==celulas[key].nome){
    celulas[key].nome=novo.trim();saveToAPI(celulas);renderSidebar();renderDetail();showToast('Nome atualizado ✓');
  }
}

// ── PRODUÇÃO MENSAL ───────────────────────────
function getChave(key){
  const mes=celulas[key].mes_selecionado!==undefined?celulas[key].mes_selecionado:new Date().getMonth();
  const ano=celulas[key].ano_selecionado||new Date().getFullYear();
  return ano+"_"+mes;
}
function updateDia(key,dia,value){
  const chave=getChave(key);
  if(!celulas[key].producao_meses)celulas[key].producao_meses={};
  if(!celulas[key].producao_meses[chave])celulas[key].producao_meses[chave]={};
  const val=parseInt(value)||0;
  celulas[key].producao_meses[chave][dia]=val;
  saveToAPI(celulas);
  const dias=celulas[key].producao_meses[chave];
  const total=Object.values(dias).reduce((a,b)=>a+(parseInt(b)||0),0);
  const maxVal=Math.max(...Object.values(dias).map(v=>parseInt(v)||0),1);
  const te=document.getElementById("prod-total");if(te)te.textContent=total.toLocaleString("pt-BR");
  const inp=document.getElementById("inp-dia-"+dia);if(inp)inp.className="prod-day-input"+(val>0?" has-value":"")+(!isAdmin?" readonly":"");
  for(let d=1;d<=31;d++){const bar=document.getElementById("bar-dia-"+d);const v=parseInt(dias[d])||0;if(bar)bar.style.width=(maxVal>0?Math.round(v/maxVal*100):0)+"%";}
}
function updateMesAno(key,campo,valor){
  if(campo==='mes')celulas[key].mes_selecionado=valor;
  if(campo==='ano')celulas[key].ano_selecionado=valor;
  saveToAPI(celulas);renderProducaoDiaria();
}
function renderProducaoDiaria(){
  const c=celulas[selected];
  const anoAtual=new Date().getFullYear();
  const mesIdx=c.mes_selecionado!==undefined?c.mes_selecionado:new Date().getMonth();
  const anoSel=c.ano_selecionado||anoAtual;
  const chave=anoSel+"_"+mesIdx;
  const dias=(c.producao_meses&&c.producao_meses[chave])?c.producao_meses[chave]:{};
  const hoje=new Date().getDate();
  const ro=!isAdmin?'readonly':'';
  const total=Object.values(dias).reduce((a,b)=>a+(parseInt(b)||0),0);
  const maxVal=Math.max(...Object.values(dias).map(v=>parseInt(v)||0),1);
  const diasComValor=Object.values(dias).filter(v=>parseInt(v)>0).length;
  let diasHTML='';
  for(let d=1;d<=31;d++){
    const val=parseInt(dias[d])||0;
    const isHoje=d===hoje&&mesIdx===new Date().getMonth()&&anoSel===anoAtual;
    const pct=maxVal>0?Math.round(val/maxVal*100):0;
    diasHTML+=`<div class="prod-day-card ${isHoje?'today':''}">
      <div class="prod-day-num">DIA ${d}</div>
      <input id="inp-dia-${d}" type="number" min="0"
        class="prod-day-input${val>0?' has-value':''}${!isAdmin?' readonly':''}"
        value="${val>0?val:''}" placeholder="0" ${ro}
        onchange="updateDia('${selected}',${d},this.value)">
      <div class="prod-day-bar-wrap"><div id="bar-dia-${d}" class="prod-day-bar" style="width:${pct}%"></div></div>
    </div>`;
  }
  document.getElementById("mainPanel").innerHTML=`
  <div>
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;flex-wrap:wrap;gap:10px">
      <div>
        <div style="font-size:24px;font-weight:800;color:#fff;letter-spacing:0.04em">📅 ${esc(c.nome)}</div>
        <div style="font-size:11px;color:#4a5568;margin-top:4px">Produção total por dia do mês</div>
      </div>
      ${isAdmin?`<button class="btn btn-red" onclick="deleteCell('${selected}')">🗑</button>`:""}
    </div>
    <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px;flex-wrap:wrap">
      <select onchange="updateMesAno('${selected}','mes',+this.value)" style="background:#0f1318;border:1px solid #1e2530;border-radius:8px;padding:8px 12px;font-family:'Courier New',monospace;font-size:14px;color:#d8dde6;cursor:pointer;outline:none">
        ${MESES.map((m,i)=>`<option value="${i}" ${i===mesIdx?'selected':''}>${m}</option>`).join('')}
      </select>
      <select onchange="updateMesAno('${selected}','ano',+this.value)" style="background:#0f1318;border:1px solid #1e2530;border-radius:8px;padding:8px 12px;font-family:'Courier New',monospace;font-size:14px;color:#d8dde6;cursor:pointer;outline:none">
        ${[anoAtual-1,anoAtual,anoAtual+1].map(a=>`<option value="${a}" ${a===anoSel?'selected':''}>${a}</option>`).join('')}
      </select>
    </div>
    <div class="prod-total-box">
      <div>
        <div style="font-size:11px;color:#4a5568;text-transform:uppercase;letter-spacing:0.12em;margin-bottom:4px">Total do mês</div>
        <div style="font-size:32px;font-weight:800;color:#00e87a;letter-spacing:0.04em" id="prod-total">${total.toLocaleString("pt-BR")}</div>
      </div>
      <div style="text-align:right">
        <div style="font-size:11px;color:#4a5568;text-transform:uppercase;letter-spacing:0.12em;margin-bottom:4px">Média diária</div>
        <div style="font-size:20px;font-weight:700;color:#3d9eff">${diasComValor>0?Math.round(total/diasComValor).toLocaleString("pt-BR"):'—'}</div>
      </div>
    </div>
    <div class="prod-day-grid">${diasHTML}</div>
  </div>`;
}

// ── METAS ────────────────────────────────────
function aplicarCor(inp,rawVal,meta,isCafe){
  inp.classList.remove('cell-ok','cell-fail','cell-adj','cafe');
  if(isCafe){inp.classList.add('cafe');return;} // 10:00 SEMPRE amarelo
  const{num,tipo}=parseCelVal(rawVal);
  if(tipo==='ajuste'){inp.classList.add('cell-adj');return;}
  if(num>0){
    if(meta>0&&num>=meta){inp.classList.add('cell-ok');return;}
    if(meta>0&&num<meta){inp.classList.add('cell-fail');return;}
    inp.classList.add('cell-ok');return;
  }
}

function syncMetasToProducao(metasKey){
  const mc=celulas[metasKey];
  const ano=mc.metas_ano||new Date().getFullYear();
  const mes=mc.metas_mes!==undefined?mc.metas_mes:new Date().getMonth();
  const dia=mc.metas_dia||new Date().getDate();
  const chave=`${ano}_${mes}_${dia}`;
  const data=(mc.metas_dias&&mc.metas_dias[chave])?mc.metas_dias[chave]:{};
  const totalGeral=ROBOS.reduce((sum,r)=>sum+[...HORAS_DIA,...HORAS_NOITE].reduce((s,h)=>s+(parseCelVal(((data[r]||{})[campoH(h)])||'').num),0),0);
  const prodKey=Object.keys(celulas).find(k=>getCellTipo(k)==='producao_mensal');
  if(!prodKey)return;
  const prodChave=`${ano}_${mes}`;
  if(!celulas[prodKey].producao_meses)celulas[prodKey].producao_meses={};
  if(!celulas[prodKey].producao_meses[prodChave])celulas[prodKey].producao_meses[prodChave]={};
  celulas[prodKey].producao_meses[prodChave][dia]=totalGeral;
}

function updateMetasCell(key,robo,campo,valor){
  const chave=getMetasChave(key);
  if(!celulas[key].metas_dias)celulas[key].metas_dias={};
  if(!celulas[key].metas_dias[chave])celulas[key].metas_dias[chave]={};
  if(!celulas[key].metas_dias[chave][robo])celulas[key].metas_dias[chave][robo]={};
  celulas[key].metas_dias[chave][robo][campo]=valor;
  syncMetasToProducao(key);
  saveToAPI(celulas);
  const rd=celulas[key].metas_dias[chave][robo];
  const meta=parseInt(rd.meta)||0;
  const subDia=HORAS_DIA.reduce((s,h)=>s+(parseCelVal(rd[campoH(h)]).num),0);
  const subNoite=HORAS_NOITE.reduce((s,h)=>s+(parseCelVal(rd[campoH(h)]).num),0);
  const totalG=subDia+subNoite;
  const elD=document.getElementById(`sub-dia-${robo}`);
  const elN=document.getElementById(`sub-noite-${robo}`);
  const elT=document.getElementById(`total-g-${robo}`);
  if(elD){elD.textContent=subDia>0?subDia:'—';elD.style.color=subDia>0?'#00e87a':'#4a5568';}
  if(elN){elN.textContent=subNoite>0?subNoite:'—';elN.style.color=subNoite>0?'#a78bfa':'#4a5568';}
  if(elT)elT.textContent=totalG>0?totalG:'—';
  if(campo.startsWith('h')){
    const horaOrigem=[...HORAS_DIA,...HORAS_NOITE].find(h=>campoH(h)===campo)||'';
    const isCafe=HORAS_CAFE.includes(horaOrigem);
    const inp=document.getElementById(`inp-${robo}-${campo}`);
    if(inp)aplicarCor(inp,valor,meta,isCafe);
  }
  if(campo==='meta'){
    [...HORAS_DIA,...HORAS_NOITE].forEach(h=>{
      const c=campoH(h);const isCafe=HORAS_CAFE.includes(h);
      const inp=document.getElementById(`inp-${robo}-${c}`);
      if(inp)aplicarCor(inp,rd[c]||'',parseInt(valor)||0,isCafe);
    });
  }
}

function updateMetasData(key,campo,valor){
  celulas[key][campo]=valor;syncMetasToProducao(key);saveToAPI(celulas);renderMetasDiaria();
}

function buildTurnoTable(c,turno,chave){
  const data=(c.metas_dias&&c.metas_dias[chave])?c.metas_dias[chave]:{};
  const podeEditar = isAdmin || isAdminMetas;
  const ro=!podeEditar?'readonly':'';
  const HORAS=turno==='dia'?HORAS_DIA:HORAS_NOITE;
  const isNoite=turno==='noite';
  const subLabel=isNoite?'Sub Noite':'Sub Dia';
  const subClass=isNoite?'sub-noite-val':'sub-dia-val';
  const subId=isNoite?'sub-noite':'sub-dia';
  const subColor=isNoite?'#a78bfa':'#00e87a';
  const horasHeader=HORAS.map(h=>{
    const isCafe=HORAS_CAFE.includes(h);
    if(isCafe)return`<th class="col-hora-cafe">☕ ${h}</th>`;
    return`<th class="${isNoite?'col-hora-noite':'col-hora'}">${h}</th>`;
  }).join('');
  const linhas=ROBOS.map(robo=>{
    const rd=(data[robo])||{};const meta=parseInt(rd.meta)||0;const cod=rd.cod||'';
    const pontos=parseInt(rd.pontos)||0;
    const horasCells=HORAS.map(h=>{
      const campo=campoH(h);const rawVal=rd[campo]||'';const{num,tipo}=parseCelVal(rawVal);
      const isCafe=HORAS_CAFE.includes(h);
      let cc='';
      if(isCafe) cc='cafe';
      else if(tipo==='ajuste')cc='cell-adj';
      else if(num>0){if(meta>0&&num>=meta)cc='cell-ok';else if(meta>0&&num<meta)cc='cell-fail';else cc='cell-ok';}
      const displayVal=rawVal!==''&&rawVal!=='0'?rawVal:'';
      const tdStyle=isCafe?'style="background:#ffb30008;"':'';
      return`<td ${tdStyle}><input id="inp-${robo}-${campo}" type="text" class="hora-inp${cc?' '+cc:''}" value="${esc(String(displayVal))}" placeholder="—" ${ro} onchange="handleMetasInput('${selected}',${robo},'${campo}',this.value)"></td>`;
    }).join('');
    const subRow=HORAS.reduce((s,h)=>s+(parseCelVal(rd[campoH(h)]).num),0);
    const totalG=isNoite?([...HORAS_DIA,...HORAS_NOITE].reduce((s,h)=>s+(parseCelVal((rd[campoH(h)])||'').num),0)):null;
    const pontosCell=isAdmin?`<td class="pontos-val"><input class="meta-inp" type="number" min="0" value="${pontos>0?pontos:''}" placeholder="pts" title="Pontos de solda da peça" style="color:#ff6a00;width:44px" onchange="updateMetasCell('${selected}',${robo},'pontos',this.value)"></td>`:'';
    return`<tr>
      <td class="robo-label">${robo}</td>
      <td class="meta-val"><input class="meta-inp" type="number" min="0" value="${meta>0?meta:''}" placeholder="—" ${ro} onchange="updateMetasCell('${selected}',${robo},'meta',this.value);renderMetasDiaria()"></td>
      <td class="cod-val"><input class="cod-inp" type="text" value="${esc(cod)}" placeholder="—" ${ro} onchange="updateMetasCell('${selected}',${robo},'cod',this.value)"></td>
      ${pontosCell}
      ${horasCells}
      <td id="${subId}-${robo}" class="${subClass}" style="color:${subRow>0?subColor:'#4a5568'}">${subRow>0?subRow:'—'}</td>
      ${isNoite?`<td id="total-g-${robo}" class="total-geral-val" style="font-size:18px;font-weight:900;padding:8px 10px;border-left:2px solid #ffb30060">${totalG>0?totalG:'—'}</td>`:''}
    </tr>`;
  }).join('');
  const rodapeHoras=HORAS.map(h=>{
    const campo=campoH(h);const isCafe=HORAS_CAFE.includes(h);
    const soma=ROBOS.reduce((s,r)=>s+(parseCelVal(((data[r]||{})[campo])||'').num),0);
    const cor=isCafe?'#ffb300':(isNoite?'#a78bfa':'#d8dde6');
    const bg=isCafe?'#ffb30010':(isNoite?'#a78bfa08':'#ffffff06');
    return`<td style="color:${cor};font-weight:800;font-size:12px;background:${bg}">${soma>0?soma:'—'}</td>`;
  }).join('');
  const subTotalTurno=ROBOS.reduce((sum,r)=>sum+HORAS.reduce((s,h)=>s+(parseCelVal(((data[r]||{})[campoH(h)])||'').num),0),0);
  const totalGeralRod=isNoite?ROBOS.reduce((sum,r)=>sum+[...HORAS_DIA,...HORAS_NOITE].reduce((s,h)=>s+(parseCelVal(((data[r]||{})[campoH(h)])||'').num),0),0):null;
  return`<div class="metas-table-wrap"><table class="metas-table">
    <thead><tr>
      <th class="col-robo">Robô</th><th class="col-meta">Meta/h</th><th class="col-cod">Cód. Peça</th>
      ${isAdmin?`<th class="col-meta" style="color:#ff6a00;font-size:10px">Pts</th>`:''}
      ${horasHeader}
      <th class="col-sub" style="color:${subColor}">${subLabel}</th>
      ${isNoite?`<th class="col-total-geral" style="font-size:11px;padding:10px 12px;min-width:110px">⚑ Total Geral do Dia</th>`:''}
    </tr></thead>
    <tbody>${linhas}
    <tr style="border-top:2px solid #1e2530">
      <td colspan="${isAdmin?4:3}" style="color:${isNoite?'#a78bfa':'#ffb300'};font-weight:800;font-size:10px;text-align:right;padding-right:8px;background:${isNoite?'#a78bfa08':'#ffb30008'}">TOTAL/HORA →</td>
      ${rodapeHoras}
      <td style="color:${subColor};font-weight:800;font-size:13px;background:${isNoite?'#a78bfa10':'#00e87a10'}">${subTotalTurno>0?subTotalTurno:'—'}</td>
      ${isNoite?`<td style="color:#ffb300;font-weight:900;font-size:20px;padding:10px 12px;background:#ffb30020;border-left:2px solid #ffb30060">${totalGeralRod>0?totalGeralRod.toLocaleString("pt-BR"):'—'}</td>`:''}
    </tr></tbody>
  </table></div>`;
}

