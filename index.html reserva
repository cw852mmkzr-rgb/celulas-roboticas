  const agora=new Date().toLocaleString("pt-BR",{day:"2-digit",month:"2-digit",year:"numeric",hour:"2-digit",minute:"2-digit"});
  const pecasFeitas = calcDesgaste(key);
  c.historico_eletrodo.push({data:agora, eletrodo:c.eletrodo, tipo:c.tipo_eletrodo||'—', pecas_feitas:pecasFeitas});
