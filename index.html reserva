function filtrarGab(busca){
  const chave = getGabChave();
  if(gabDados[chave]) gabDados[chave]._busca = busca;
  const termo = busca.toLowerCase().trim();
  const tbody = document.getElementById("gabTbody");
  if(!tbody) return;
  const rows = tbody.querySelectorAll("tr[data-cod]");
  let visiveis = 0;
  rows.forEach(tr=>{
    const cod = tr.getAttribute("data-cod")||"";
    const show = !termo || cod.toLowerCase().includes(termo);
    tr.style.display = show?"":"none";
    if(show) visiveis++;
  });
  const count = document.getElementById("gabBuscaCount");
  if(count) count.textContent = `${visiveis} código(s)`;
}

function abrirModalNovaCodGab(){
  const cod = prompt("Código da peça/gabarito:");
  if(!cod||!cod.trim()) return;
  const chave = getGabChave();
  if(!gabDados[chave]) gabDados[chave]={codigos:[]};
  if(!gabDados[chave].codigos) gabDados[chave].codigos=[];
  if(gabDados[chave].codigos.includes(cod.trim())){showToast("Código já existe",true);return;}
  gabDados[chave].codigos.push(cod.trim().toUpperCase());
  saveGabDados();
  renderGabaritagem();
}

function excluirCodGab(cod){
  if(!confirm(`Excluir código "${cod}" e todos os dados?`)) return;
  const chave = getGabChave();
  gabDados[chave].codigos = gabDados[chave].codigos.filter(c=>c!==cod);
  delete gabDados[chave][cod];
  saveGabDados();
  renderGabaritagem();
}
